{
  "providers": {
    "openrouter": {
      "apiKey": "sk-or-v1-xxx",
      "apiBase": "https://openrouter.ai/api/v1",
      "model": "deepseek/deepseek-chat-v3-0324",
      "timeout": 120
    },
    "glm": {
      "apiKey": "xxx.xxx",
      "apiBase": "https://open.bigmodel.cn/api/anthropic",
      "model": "glm-5",
      "timeout": 120
    },
    "minimax": {
      "apiKey": "sk-cp-xxx",
      "apiBase": "https://api.minimaxi.com/anthropic",
      "model": "MiniMax-M2.5"
    },
    "qwencoder": {
      "apiKey": "sk-sp-xxx",
      "apiBase": "https://coding.dashscope.aliyuncs.com/v1",
      "model": "qwen3.5-plus",
      "timeout": 120
    },
    "qwen": {
      "apiKey": "sk-xxx",
      "model": "qwen3.5-plus"
    }
  },
  "agents": {
    "workspace": "~/.lingguard/workspace",
    "provider": "qwencoder",
    "multimodalProvider": "qwencoder",
    "maxToolIterations": 50,
    "memoryWindow": 50,
    "systemPrompt": "你是灵侍，一个乐于助人的 AI 助手。你可以使用工具帮助用户完成各种任务。\n\n## 核心规则\n\n1. **工具描述包含完整的触发规则**，请仔细阅读 skill 和 task 工具的描述\n2. **加载 skill 后必须执行**，不要只返回文本说明\n3. **只有复杂编码任务才使用 subagent**，其他任务直接执行",
    "sessionCompress": {
      "enabled": true,
      "threshold": 50,
      "keepRecent": 5,
      "summaryMaxLen": 500
    },
    "memory": {
      "enabled": true,
      "path": "~/.lingguard/memory",
      "recentDays": 3,
      "maxHistoryLines": 1000,
      "maxDailyLogAge": 30,
      "autoRecall": true,
      "autoRecallTopK": 3,
      "autoRecallMinScore": 0.3,
      "autoCapture": true,
      "captureMaxChars": 500,
      "refine": {
        "enabled": true,
        "similarityThreshold": 0.85,
        "keepBackup": true,
        "maxEntriesPerCategory": 20
      },
      "vector": {
        "enabled": false,
        "embedding": {
          "provider": "qwen",
          "model": "text-embedding-v4",
          "apiBase": "https://dashscope.aliyuncs.com/compatible-mode/v1",
          "dimension": 1024
        },
        "search": {
          "vectorWeight": 0.7,
          "bm25Weight": 0.3,
          "defaultTopK": 10,
          "rerank": {
            "enabled": false,
            "provider": "qwen",
            "model": "qwen3-rerank",
            "apiBase": "https://dashscope.aliyuncs.com/api/v1/services/rerank/text-rerank/text-rerank"
          }
        }
      }
    }
  },
  "channels": {
    "feishu": {
      "enabled": true,
      "appId": "xxx",
      "appSecret": "xxx"
    }
  },
  "heartbeat": {
    "enabled": true,
    "interval": 30
  },
  "tools": {
    "restrictToWorkspace": true,
    "websearch": {
      "tavilyApiKey": "tvly-dev-xxx",
      "bochaApiKey": "sk-xxx",
      "maxResults": 5
    },
    "webfetch": {
      "maxChars": 50000
    },
    "mcpServers": {
    },
    "opencode": {
      "enabled": false,
      "baseURL": "http://127.0.0.1:4096",
      "timeout": 1200
    },
    "aigc": {
      "enabled": false,
      "provider": "qwen",
      "apiBase": "https://dashscope.aliyuncs.com/api/v1",
      "textToImage": "wan2.6-t2i",
      "textToVideo": "wan2.6-t2v",
      "imageToVideo": "wan2.6-i2v-flash",
      "videoToVideo": "wan2.6-r2v-flash",
      "imageToVideoDuration": 15
    },
    "tts": {
      "enabled": false,
      "provider": "qwen",
      "apiBase": "https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation",
      "model": "qwen3-tts-flash",
      "voice": "Cherry"
    },
    "speech": {
      "enabled": false,
      "provider": "qwen",
      "apiBase": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "model": "qwen3-asr-flash",
      "format": "opus",
      "language": "zh",
      "timeout": 60
    },
    "moltbook": {
      "enabled": false
    },
    "clawhub": {
      "enabled": false,
      "apiToken": "xxx"
    },
    "cron": {
      "enabled": true,
      "storePath": "~/.lingguard/cron/jobs.json"
    },
    "calendar": {
      "enabled": true,
      "default": "dingtalk",
      "accounts": [
        {
          "name": "feishu",
          "url": "https://caldav.feishu.cn",
          "username": "xxx",
          "password": "xxx",
          "timeout": 30
        },
        {
          "name": "dingtalk",
          "url": "https://calendar.dingtalk.com/dav",
          "username": "xxx",
          "password": "xxx"
        }
      ]
    }
  },
  "logging": {
    "level": "info",
    "format": "text",
    "output": "~/.lingguard/logs/lingguard.log",
    "maxSize": 10,
    "maxAge": 7,
    "maxBackups": 5,
    "compress": false
  },
  "server": {
    "enabled": true,
    "host": "127.0.0.1",
    "port": 18989,
    "cors": {
      "allowedOrigins": ["*"]
    },
    "api": {
      "auth": {
        "type": "token",
        "tokens": ["1234567890"]
      }
    },
    "webui": {
      "taskboard": {
        "dbPath": "~/.lingguard/webui/taskboard.db",
        "trackUserRequests": true,
        "syncSubagent": true,
        "syncCron": true
      },
      "trace": {
        "dbPath": "~/.lingguard/webui/trace.db"
      },
      "webchat": {
        "maxConnections": 100,
        "maxConnectionsPerIP": 5
      }
    }
  }
}
