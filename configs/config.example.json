{
  "_comment": "LingGuard 配置文件 - 参考 nanobot Provider Registry 机制",
  "_docs": "https://github.com/HKUDS/nanobot",

  "providers": {
    "_comment": "==================== LLM 提供商配置 ====================",
    "_note": "apiBase 和 model 使用 ProviderSpec 默认值，只需配置 apiKey 即可",

    "openrouter": {
      "_comment": "OpenRouter - 推荐！可访问所有主流模型",
      "_docs": "https://openrouter.ai",
      "apiKey": "sk-or-v1-xxx",
      "model": "anthropic/claude-opus-4"
    },

    "anthropic": {
      "_comment": "Anthropic Claude 直连",
      "apiKey": "sk-ant-xxx"
    },

    "openai": {
      "_comment": "OpenAI GPT 直连",
      "apiKey": "sk-xxx"
    },

    "deepseek": {
      "_comment": "DeepSeek 深度求索",
      "apiKey": "sk-xxx"
    },

    "qwen": {
      "_comment": "阿里云通义千问",
      "apiKey": "sk-xxx"
    },

    "glm": {
      "_comment": "智谱 GLM - 智谱 AI",
      "apiKey": "xxx.xxx",
      "apiBase": "https://open.bigmodel.cn/api/anthropic"
    },

    "moonshot": {
      "_comment": "月之暗面 Kimi",
      "apiKey": "sk-xxx"
    },

    "groq": {
      "_comment": "Groq - 高速推理平台",
      "apiKey": "gsk_xxx"
    },

    "gemini": {
      "_comment": "Google Gemini",
      "apiKey": "AIza-xxx"
    },

    "minimax": {
      "_comment": "MiniMax AI",
      "apiKey": "xxx",
      "apiBase": "https://api.minimaxi.com/anthropic"
    },

    "vllm": {
      "_comment": "vLLM - 本地模型服务（需先启动 vLLM 服务器）",
      "apiKey": "dummy",
      "apiBase": "http://localhost:8000/v1",
      "model": "meta-llama/Llama-3.1-8B-Instruct"
    }
  },

  "agents": {
    "_comment": "==================== Agent 代理配置 ====================",
    "workspace": "~/.lingguard/workspace",
    "provider": "openrouter",
    "maxToolIterations": 20,
    "memoryWindow": 50,
    "systemPrompt": "你是灵侍，一个乐于助人的 AI 助手。你可以使用工具帮助用户完成各种任务。",
    "memory": {
      "_comment": "记忆系统配置（参考 OpenClaw 自动捕获/召回机制）",
      "enabled": true,
      "recentDays": 3,
      "maxHistoryLines": 1000,
      "autoRecall": true,
      "autoRecallTopK": 3,
      "autoRecallMinScore": 0.3,
      "autoCapture": true,
      "captureMaxChars": 500,
      "vector": {
        "_comment": "向量检索配置（可选，需要配置 Embedding API）",
        "enabled": false,
        "embedding": {
          "provider": "qwen",
          "model": "text-embedding-v4",
          "dimension": 1024
        },
        "search": {
          "vectorWeight": 0.7,
          "bm25Weight": 0.3,
          "defaultTopK": 10,
          "minScore": 0.5,
          "rerank": {
            "enabled": false,
            "provider": "qwen",
            "model": "qwen3-vl-rerank"
          }
        },
        "database": {
          "path": "~/.lingguard/memory/vectors.db",
          "dimension": 1024
        }
      }
    }
  },

  "channels": {
    "_comment": "==================== 渠道配置 ====================",

    "feishu": {
      "_comment": "飞书机器人 - WebSocket 长连接，无需公网 IP",
      "enabled": false,
      "appId": "cli_xxx",
      "appSecret": "xxx",
      "encryptKey": "",
      "verificationToken": "",
      "allowFrom": []
    },

    "qq": {
      "_comment": "QQ机器人 - WebSocket Gateway，支持私聊消息",
      "_docs": "https://bot.q.qq.com",
      "enabled": false,
      "appId": "xxx",
      "secret": "xxx",
      "allowFrom": []
    }
  },

  "tools": {
    "_comment": "==================== 工具配置 ====================",
    "restrictToWorkspace": true,
    "tavilyApiKey": "",
    "webMaxChars": 50000,
    "mcpServers": {
      "_comment": "MCP (Model Context Protocol) 服务器配置 - 兼容 Claude Desktop / Cursor 格式",
      "_docs": "https://modelcontextprotocol.io",
      "filesystem": {
        "_comment": "文件系统 MCP 服务器示例",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/dir"]
      },
      "fetch": {
        "_comment": "HTTP 请求 MCP 服务器示例",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-fetch"]
      }
    },
    "opencode": {
      "_comment": "OpenCode 代码助手配置",
      "enabled": false,
      "baseURL": "http://127.0.0.1:4096",
      "timeout": 1200
    },
    "aigc": {
      "_comment": "AI 内容生成配置 - 使用阿里云通义万相",
      "enabled": false,
      "provider": "qwen",
      "textToImage": "wan2.6-t2i",
      "textToVideo": "wan2.6-t2v",
      "imageToVideo": "wan2.6-i2v-flash",
      "videoToVideo": "wan2.6-r2v-flash",
      "imageToVideoDuration": 15,
      "_durationNote": "图生视频/参考视频时长（秒）：默认 5，最大 15"
    },
    "moltbook": {
      "_comment": "Moltbook AI 社交网络配置",
      "_docs": "https://www.moltbook.com/skill.md",
      "_note": "凭证存储在 ~/.lingguard/moltbook/credentials.json",
      "enabled": false
    }
  },

  "storage": {
    "_comment": "==================== 存储配置 ====================",
    "type": "file",
    "path": "~/.lingguard/memory"
  },

  "logging": {
    "_comment": "==================== 日志配置 ====================",
    "level": "info",
    "format": "text",
    "output": "~/.lingguard/logs/lingguard.log",
    "maxSize": 10,
    "maxAge": 7,
    "maxBackups": 5,
    "compress": false
  },

  "speech": {
    "_comment": "==================== 语音识别配置 (ASR) ====================",
    "_desc": "用于飞书语音消息转文字，使用阿里云通义千问 Paraformer",
    "_docs": "https://help.aliyun.com/zh/model-studio/developer-reference/paraformer",
    "_note": "apiKey 自动从 providers.qwen 继承，无需单独配置",
    "enabled": false,
    "provider": "qwen",
    "model": "qwen3-asr-flash",
    "format": "opus",
    "language": "zh",
    "timeout": 60
  },

  "tts": {
    "_comment": "==================== 语音合成配置 (TTS) ====================",
    "_desc": "文字转语音，使用阿里云通义千问 CosyVoice",
    "_docs": "https://help.aliyun.com/zh/model-studio/developer-reference/tongyi-qianwen-tts",
    "_note": "apiKey 自动从 providers.qwen 继承，无需单独配置",
    "enabled": false,
    "provider": "qwen",
    "model": "qwen3-tts-flash",
    "voice": "Cherry",
    "_voices": "可用音色: Cherry(甜美女声), Serena(温柔女声), Ethan(沉稳男声), Chelsie(活力女声), Momo(可爱童声), Vivian(知性女声), Moon(亲切男声), Maia(清澈女声), Kai(磁性男声)",
    "timeout": 60,
    "outputDir": "~/.lingguard/workspace/generated"
  },

  "cron": {
    "_comment": "==================== 定时任务配置 ====================",
    "enabled": true,
    "storePath": "~/.lingguard/cron/jobs.json"
  },

  "heartbeat": {
    "_comment": "==================== 心跳服务配置 ====================",
    "_desc": "定期唤醒 Agent 检查 HEARTBEAT.md 中的任务",
    "enabled": true,
    "interval": 30
  }
}
